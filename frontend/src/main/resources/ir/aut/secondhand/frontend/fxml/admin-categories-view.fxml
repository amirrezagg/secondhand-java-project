<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.aut.secondhand.frontend.AdminCategoriesController"
            styleClass="admin-root">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15"
              styleClass="admin-header">

            <padding>
                <Insets top="18"
                        right="25"
                        bottom="18"
                        left="25"/>
            </padding>

            <Label text="Category Management"
                   styleClass="admin-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back"
                    onAction="#backToDashboard"
                    styleClass="admin-logout-button"/>

        </HBox>
    </top>

    <center>
        <VBox spacing="18"
              styleClass="admin-content">

            <padding>
                <Insets top="25"
                        right="35"
                        bottom="25"
                        left="35"/>
            </padding>

            <Label text="Categories"
                   styleClass="admin-section-title"/>

            <Separator/>

            <HBox spacing="10">

                <TextField fx:id="categoryField"
                           promptText="Category name"
                           HBox.hgrow="ALWAYS"/>

                <Button text="Add"
                        onAction="#addCategory"/>

            </HBox>

            <ListView fx:id="categoriesList"
                      VBox.vgrow="ALWAYS"/>

            <HBox spacing="10">

                <Button text="Edit"
                        onAction="#editCategory"/>

                <Button text="Delete"
                        onAction="#deleteCategory"/>

            </HBox>

            <Label fx:id="messageLabel"
                   styleClass="admin-message-label"/>

        </VBox>
    </center>

</BorderPane>