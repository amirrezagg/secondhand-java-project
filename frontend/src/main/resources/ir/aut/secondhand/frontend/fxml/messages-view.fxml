<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.aut.secondhand.frontend.MessagesController"
            styleClass="messages-root">

    <!-- Top navigation -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              styleClass="messages-main-header">

            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>

            <Button text="Back"
                    onAction="#goBack"
                    styleClass="primary-button"/>

            <Label text="Messages"
                   styleClass="messages-page-title"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.30"
                   styleClass="messages-split-pane">

            <!-- Left sidebar -->
            <VBox prefWidth="340"
                  minWidth="280"
                  spacing="10"
                  styleClass="conversation-sidebar">

                <padding>
                    <Insets top="15" right="12" bottom="15" left="12"/>
                </padding>

                <Label text="Conversations"
                       styleClass="sidebar-title"/>

                <ListView fx:id="conversationListView"
                          VBox.vgrow="ALWAYS"
                          styleClass="conversation-list"/>

            </VBox>

            <!-- Right chat section -->
            <BorderPane styleClass="chat-pane"
                        minHeight="0">

                <!-- Selected conversation header -->
                <top>
                    <HBox alignment="CENTER_LEFT"
                          spacing="12"
                          styleClass="chat-header">

                        <padding>
                            <Insets top="12" right="18" bottom="12" left="18"/>
                        </padding>

                        <Label text="AR"
                               styleClass="chat-avatar"/>

                        <VBox spacing="3">
                            <Label fx:id="conversationTitleLabel"
                                   text="Select a conversation"
                                   styleClass="chat-person-name"/>

                            <Label fx:id="conversationSubtitleLabel"
                                   text="Choose a conversation from the left"
                                   styleClass="chat-person-status"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="onlineStatusLabel"
                               text=""
                               styleClass="online-status"/>
                    </HBox>
                </top>

                <!-- Messages area -->
                <center>
                    <ListView fx:id="messageListView"
                              minHeight="0"
                              styleClass="message-list"/>
                </center>

                <!-- Message composer -->
                <bottom>
                    <HBox alignment="CENTER"
                          spacing="10"
                          minHeight="65"
                          prefHeight="65"
                          styleClass="message-composer">

                        <padding>
                            <Insets top="10" right="16" bottom="10" left="16"/>
                        </padding>


                        <TextField fx:id="messageField"
                                   promptText="Write a message..."
                                   HBox.hgrow="ALWAYS"
                                   styleClass="message-input"/>

                        <Button text="Send"
                                onAction="#sendMessage"
                                styleClass="send-button"/>
                    </HBox>
                </bottom>

            </BorderPane>

        </SplitPane>
    </center>

</BorderPane>