<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.aut.secondhand.frontend.AdminUsersController"
            styleClass="admin-root">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15"
              styleClass="admin-header">

            <padding>
                <Insets top="18"
                        right="25"
                        bottom="18"
                        left="25"/>
            </padding>

            <Label text="User Management"
                   styleClass="admin-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back"
                    onAction="#backToDashboard"
                    styleClass="admin-logout-button"/>

        </HBox>
    </top>

    <center>
        <VBox spacing="18"
              styleClass="admin-content">

            <padding>
                <Insets top="25"
                        right="35"
                        bottom="25"
                        left="35"/>
            </padding>

            <Label text="Users"
                   styleClass="admin-section-title"/>

            <Separator/>

            <TableView fx:id="usersTable"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="usernameColumn"
                                 text="Username"
                                 prefWidth="180"/>

                    <TableColumn fx:id="emailColumn"
                                 text="Email"
                                 prefWidth="260"/>

                    <TableColumn fx:id="statusColumn"
                                 text="Status"
                                 prefWidth="140"/>

                    <TableColumn fx:id="actionColumn"
                                 text="Action"
                                 prefWidth="180"/>
                </columns>

            </TableView>

            <Label fx:id="messageLabel"
                   text=""
                   styleClass="admin-message-label"/>

        </VBox>
    </center>

</BorderPane>