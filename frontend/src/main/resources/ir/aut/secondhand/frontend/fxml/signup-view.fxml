<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ir.aut.secondhand.frontend.SignUpController"
           styleClass="auth-root">

    <VBox alignment="CENTER">

        <VBox fx:id="loginCard"
              alignment="CENTER"
              spacing="15"
              maxWidth="350">

            <padding>
                <Insets top="35" right="35" bottom="35" left="35"/>
            </padding>

            <Label text="Create Account"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

            <TextField fx:id="nameField"
                       promptText="Full Name"/>
            <Label fx:id="nameErrorLabel"
                   textFill="red"/>

            <TextField fx:id="usernameField"
                       promptText="Username"/>

            <Label fx:id="usernameErrorLabel"
                   textFill="red"/>

            <TextField fx:id="emailField"
                       promptText="Email"/>

            <Label fx:id="emailErrorLabel"
                   textFill="red"/>
            <HBox spacing="8" alignment="CENTER">
                <Label text="+98"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <TextField fx:id="phoneField"
                           promptText="9123456789"/>
            </HBox>

            <Label fx:id="phoneErrorLabel"
                   textFill="red"/>
            <PasswordField fx:id="passwordField"
                           promptText="Password"/>

            <Label fx:id="passwordErrorLabel"
                   textFill="red"/>
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Confirm Password"/>
            <Label fx:id="confirmPasswordErrorLabel"
                   textFill="red"/>


            <Button text="Sign Up"
                    onAction="#signUp"
                    maxWidth="Infinity"/>

            <Label fx:id="messageLabel"
                   text=""
                   style="-fx-text-fill:red;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?"/>
                <Hyperlink text="Login"
                           onAction="#openLogin"/>
            </HBox>

        </VBox>

    </VBox>

</StackPane>