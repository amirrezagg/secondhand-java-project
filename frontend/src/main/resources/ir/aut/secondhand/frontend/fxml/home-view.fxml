<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.TilePane?>

<?import javafx.scene.control.ComboBox?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.aut.secondhand.frontend.HomeController"
            styleClass="home-root">

    <top>
        <VBox spacing="12"
              styleClass="home-top-container">

            <!-- ردیف اصلی: لوگو، سرچ و دکمه‌های منو -->
            <HBox spacing="12"
                  alignment="CENTER_LEFT"
                  styleClass="home-main-bar">

                <Label text="SecondHand"
                       styleClass="home-logo"/>

                <TextField fx:id="searchField"
                           promptText="Search advertisements..."
                           HBox.hgrow="ALWAYS"
                           styleClass="home-search"/>

                <Button fx:id="addAdvertisementButton"
                        text="Add Advertisement"
                        onAction="#addAdvertisement"/>

                <Button text="Messages"
                        onAction="#openMessages"/>

                <Button text="Favorites"
                        onAction="#openFavorites"/>

                <Button text="Profile"
                        onAction="#openProfile"/>

                <Button text="Logout"
                        onAction="#logout"/>
            </HBox>

            <!-- ردیف فیلترها -->
            <HBox spacing="10"
                  alignment="CENTER_LEFT"
                  styleClass="home-filter-bar">

                <Label text="Filters:"
                       styleClass="filter-title"/>

                <ComboBox fx:id="categoryFilterBox"
                          promptText="Category"
                          prefWidth="150"/>

                <ComboBox fx:id="cityFilterBox"
                          promptText="City"
                          prefWidth="130"/>

                <TextField fx:id="minPriceField"
                           promptText="Min Price"
                           prefWidth="130"/>

                <TextField fx:id="maxPriceField"
                           promptText="Max Price"
                           prefWidth="130"/>

                <ComboBox fx:id="sortBox"
                          promptText="Sort By"
                          prefWidth="150"/>

                <Button text="Clear Filters"
                        onAction="#clearFilters"
                        styleClass="clear-filter-button"/>
            </HBox>

        </VBox>
    </top>


    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent;">
            <content>
                <TilePane fx:id="advertisementTilePane"
                          hgap="20"
                          vgap="20"
                          prefColumns="4"
                          alignment="TOP_RIGHT"
                          style="-fx-padding: 30;"/>
            </content>
        </ScrollPane>
    </center>





</BorderPane>