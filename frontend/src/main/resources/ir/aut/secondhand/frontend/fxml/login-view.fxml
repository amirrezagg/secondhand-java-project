<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ir.aut.secondhand.frontend.LoginController"
           styleClass="auth-root">

    <VBox alignment="CENTER">

        <VBox fx:id="loginCard"
              alignment="CENTER"
              spacing="15"
              maxWidth="320">

            <padding>
                <Insets top="35" right="35" bottom="35" left="35"/>
            </padding>

            <Label text="Login to App"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <TextField fx:id="usernameField"
                       promptText="Username"/>

            <PasswordField fx:id="passwordField"
                           promptText="Password"/>

            <Button text="Login"
                    onAction="#login"
                    maxWidth="Infinity"/>

            <Label fx:id="messageLabel"
                   text=""
                   style="-fx-text-fill: red;
                          -fx-font-size: 12px;"/>

            <HBox alignment="CENTER" spacing="5">

                <Label text="Don't have an account?"/>

                <Hyperlink text="Sign up"
                           onAction="#openSignUp"/>

            </HBox>

        </VBox>

    </VBox>

</StackPane>