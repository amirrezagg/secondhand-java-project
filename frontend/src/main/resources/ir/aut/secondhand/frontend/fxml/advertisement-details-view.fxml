<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.aut.secondhand.frontend.AdvertisementDetailsController"
            styleClass="add-ad-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-padding: 15; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <Button text="Back" onAction="#goBack"/>
            <Label text="Advertisement Details"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;" alignment="TOP_CENTER">

                <ImageView fx:id="mainImageView"
                           fitWidth="420"
                           fitHeight="260"
                           preserveRatio="false"/>

                <HBox fx:id="thumbnailBox"
                      spacing="10"
                      alignment="CENTER"
                      prefHeight="90"/>

                <VBox spacing="10" maxWidth="600"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 12;">

                    <Label fx:id="titleLabel"
                           text="لپ‌تاپ دست دوم"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

                    <Label fx:id="priceLabel"
                           text="۴۵ میلیون تومان"
                           style="-fx-font-size: 18px; -fx-text-fill: #1E88E5; -fx-font-weight: bold;"/>

                    <Label fx:id="cityCategoryLabel"
                           text="تهران • لوازم الکترونیکی"
                           style="-fx-font-size: 14px; -fx-text-fill: #6b7280;"/>

                    <Separator/>

                    <Label text="Description"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label fx:id="descriptionLabel"
                           text="این آگهی نمونه برای نمایش صفحه جزئیات آگهی است."
                           wrapText="true"
                           style="-fx-font-size: 14px;"/>

                    <Separator/>

                    <Label text="Seller"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label fx:id="sellerLabel"
                           text="Seller: کاربر نمونه"/>

                    <VBox spacing="6">

                        <Label text="Seller Rating"
                               style="-fx-font-size:16px;
                  -fx-font-weight:bold;"/>

                        <HBox spacing="8"
                              alignment="CENTER_LEFT">

                            <Label fx:id="sellerRatingStarsLabel"
                                   text="☆☆☆☆☆"
                                   style="-fx-font-size:22px;
                      -fx-text-fill:#f59e0b;"/>

                            <Label fx:id="averageRatingLabel"
                                   text="0.0"
                                   style="-fx-font-size:14px;
                      -fx-font-weight:bold;"/>

                            <Label fx:id="ratingCountLabel"
                                   text="(0 ratings)"
                                   style="-fx-font-size:13px;"/>

                        </HBox>

                    </VBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="addToFavoritesButton"
                                text="Add to Favorites"
                                onAction="#addToFavorites"/>
                        <Button fx:id="messageSellerButton"
                                text="Message Seller"
                                onAction="#messageSeller"/>
                        <Button fx:id="rateSellerButton"
                                text="Rate Seller"
                                onAction="#openRatingPage"/>
                    </HBox>

                    <Label fx:id="favoriteMessageLabel"
                           text=""
                           wrapText="true"/>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>