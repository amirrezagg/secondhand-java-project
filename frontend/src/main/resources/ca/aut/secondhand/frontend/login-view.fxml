<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Hyperlink?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ir.aut.secondhand.frontend.LoginController"
      alignment="CENTER"
      spacing="15"
      style="-fx-background-color: linear-gradient(to bottom, #4A90E2, #FFFFFF);">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Login to App"
           style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField"
            promptText="Username"
            maxWidth="250"/>

    <PasswordField fx:id="passwordField"
            promptText="Password"
            maxWidth="250"/>

    <Button fx:id="loginButton"
            text="Login"
            maxWidth="250"
            onAction="#login"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Don't have an account?"/>
        <Hyperlink text="Sign up"/>
    </HBox>

</VBox>